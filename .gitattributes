
# Enable highlight in GitHub for `.snap` files
# *.snap linguist-language=markdown

# Ignore fixtures
crates/rolldown/tests/**/*.js -linguist-detectable
crates/rolldown/tests/**/*.jsx -linguist-detectable
crates/rolldown/tests/**/*.ts -linguist-detectable
crates/rolldown/tests/**/*.tsx -linguist-detectable

packages/rolldown/tests/stability/**/*.js -linguist-detectable 

# https://github.com/rolldown/rolldown/issues/1354
* text eol=lf
*.png -text
*.jpg -text
*.bin -text
*.md text eol=lf

# Font files must be treated as binary; otherwise `* text eol=lf` above
# corrupts them during check-in / checkout.
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary
*.eot   binary
