{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>Boshen/renovate"],
  "automerge": false,
  "ignorePaths": ["**/node_modules/**", "**/examples/**", "**/crates/rolldown/tests/**"],
  "packageRules": [
    {
      "groupName": "rolldown-plugin-dts",
      "matchManagers": ["npm"],
      "matchPackageNames": ["rolldown-plugin-dts"],
      "schedule": ["at any time"]
    },
    {
      "description": "idna_adapter is pinned to 1.0.0 to keep the lighter unicode-rs backend (see #9811)",
      "matchManagers": ["cargo"],
      "matchPackageNames": ["idna_adapter"],
      "enabled": false
    }
  ]
}
