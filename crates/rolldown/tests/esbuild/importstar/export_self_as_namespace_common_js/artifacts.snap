# Assets

## entry.js

```js
"use strict";


//#region entry.js
var ns = {};
__export(ns, {
	foo: () => foo,
	ns: () => ns
});
const foo = 123;

//#endregion
exports.foo = foo
Object.defineProperty(exports, 'ns', {
  enumerable: true,
  get: function () {
    return ns;
  }
});
