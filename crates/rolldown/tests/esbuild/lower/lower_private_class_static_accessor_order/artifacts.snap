# Assets

## entry.js

```js
import assert from "node:assert";
//#region entry.js
let Foo = class Foo {
	static bar = Foo.#foo;
	static get #foo() {
		return 123;
	}
};
assert.equal(Foo.bar, 123);
let FooThis = class {
	static bar = this.#foo;
	static get #foo() {
		return 123;
	}
};
assert.equal(FooThis.bar, 123);
//#endregion

```
