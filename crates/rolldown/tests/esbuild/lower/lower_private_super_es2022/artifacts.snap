# Assets

## entry.js

```js

//#region foo1.js
var foo1 = class extends x {
	#foo() {
		super.foo();
	}
};

//#endregion
//#region foo2.js
var foo2 = class extends x {
	#foo() {
		super.foo++;
	}
};

//#endregion
//#region foo3.js
var foo3 = class extends x {
	static #foo() {
		super.foo();
	}
};

//#endregion
//#region foo4.js
var foo4 = class extends x {
	static #foo() {
		super.foo++;
	}
};

//#endregion
//#region foo5.js
var foo5 = class extends x {
	#foo = () => {
		super.foo();
	};
};

//#endregion
//#region foo6.js
var foo6 = class extends x {
	#foo = () => {
		super.foo++;
	};
};

//#endregion
//#region foo7.js
var foo7 = class extends x {
	static #foo = () => {
		super.foo();
	};
};

//#endregion
//#region foo8.js
var foo8 = class extends x {
	static #foo = () => {
		super.foo++;
	};
};

//#endregion
export { foo1, foo2, foo3, foo4, foo5, foo6, foo7, foo8 };
