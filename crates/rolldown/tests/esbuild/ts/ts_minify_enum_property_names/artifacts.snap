# Assets

## entry.js

```js
shouldNotBeComputed(class {
	[100] = 100;
	"200" = 200;
	["300"] = 300;
	["str 1"] = "str 1";
	[123] = 123;
	["str 2"] = "str 2";
	[321] = 321;
}, {
	[100]: 100,
	"200": 200,
	["300"]: 300,
	["str 1"]: "str 1",
	[123]: 123,
	["str 2"]: "str 2",
	[321]: 321
});
mustBeComputed({ ["__proto__"]: null }, { ["__proto__"]: null }, class {
	["constructor"]() {}
}, class {
	["constructor"]() {}
}, class {
	static ["prototype"]() {}
}, class {
	static ["prototype"]() {}
});
//#endregion

```
