# Assets

## a1.js

```js
import { t as shared } from "./shared.js";
import assert from "node:assert";
//#region a1.js
assert.strictEqual(shared, "shared");
import("./dyn.js").then((m) => {
	assert.strictEqual(m.dynVal, "dyn:shared");
});
//#endregion

```

## a2.js

```js
import { t as shared } from "./shared.js";
import assert from "node:assert";
//#region a2.js
assert.strictEqual(shared, "shared");
import("./dyn.js").then((m) => {
	assert.strictEqual(m.dynVal, "dyn:shared");
});
//#endregion

```

## dyn.js

```js
import { t as shared } from "./shared.js";
//#region dyn.js
const dynVal = `dyn:${shared}`;
//#endregion
export { dynVal };

```

## shared.js

```js
//#region shared.js
const shared = "shared";
//#endregion
export { shared as t };

```

