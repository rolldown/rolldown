# Assets

## foo.js

```js
// HIDDEN [\0rolldown/runtime.js]
//#region foo.js
var foo_exports = /* @__PURE__ */ __exportAll({ foo: () => foo });
const foo = 1;
//#endregion
export { foo_exports as n, foo as t };

```

## foo2.js

```js
import { t as foo } from "./foo.js";
export { foo };

```

## main.js

```js
import { n as foo_exports } from "./foo.js";
import assert from "node:assert";
//#region main.js
assert.deepEqual(foo_exports, {
	[Symbol.toStringTag]: "Module",
	foo: 1
});
import("./foo2.js").then((mod) => {
	assert.deepEqual(mod, foo_exports);
});
//#endregion

```

