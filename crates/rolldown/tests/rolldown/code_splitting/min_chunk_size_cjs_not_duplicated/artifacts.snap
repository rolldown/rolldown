## util.js

```js
//#region util.js
const value = "shared-value";
function getValue() {
	return value;
}
//#endregion
Object.defineProperty(exports, "getValue", {
	enumerable: true,
	get: function() {
		return getValue;
	}
});
Object.defineProperty(exports, "value", {
	enumerable: true,
	get: function() {
		return value;
	}
});

```
