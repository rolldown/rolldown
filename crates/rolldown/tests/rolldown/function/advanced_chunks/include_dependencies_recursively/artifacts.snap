## vendor.js

```js
import { b as __esm } from "./rolldown-runtime.js";

//#region bar.js
var bar;
var init_bar = __esm({ "bar.js"() {
	bar = "bar";
} });

//#endregion
//#region foo.js
var foo;
var init_foo = __esm({ "foo.js"() {
	init_bar();
	foo = "foo " + bar;
} });

//#endregion
export { init_foo as b, foo as c };
```
