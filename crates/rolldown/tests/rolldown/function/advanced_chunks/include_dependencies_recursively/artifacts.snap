# Assets

## main.js

```js
import { b as __esm } from "./rolldown-runtime.js";
import { b as init_foo, c as foo } from "./vendor.js";
import nodeAssert from "node:assert";

//#region main.js
var init_main = __esm({ "main.js"() {
	init_foo();
	nodeAssert.strictEqual(foo, "foo bar");
} });

//#endregion
init_main();
```
