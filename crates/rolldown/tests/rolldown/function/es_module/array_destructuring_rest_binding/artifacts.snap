import assert from "node:assert";
// HIDDEN [\0rolldown/runtime.js]
//#region lib.js
var stages;
function init_lib() {
	return (init_lib = __esmMin((() => {
		stages = {
			a: "1",
			b: "2",
			c: "3"
		};
	})))();
}
//#endregion
//#region main.js
var first, rest, all;
function init_main() {
	return (init_main = __esmMin((() => {
		init_lib();
		[first, ...rest] = Object.values(stages);
		if (!first) throw new Error("empty");
		all = [first, ...rest];
		assert.deepStrictEqual(all, [
			"1",
			"2",
			"3"
		]);
	})))();
}
//#endregion
export { init_main as n, all as t };

```
