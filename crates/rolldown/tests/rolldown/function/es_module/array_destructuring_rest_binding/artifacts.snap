# Assets

## main.js

```js
import assert from "node:assert";
//#endregion
//#region main.js
const [first, ...rest] = Object.values({
	a: "1",
	b: "2",
	c: "3"
});
if (!first) throw new Error("empty");
const all = [first, ...rest];
assert.deepStrictEqual(all, [
	"1",
	"2",
	"3"
]);
//#endregion
export { all };

```
