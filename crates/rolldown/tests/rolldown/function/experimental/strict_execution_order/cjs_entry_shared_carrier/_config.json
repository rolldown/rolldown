{
  "configName": "on-demand",
  "config": {
    "input": [
      {
        "name": "a",
        "import": "./a.cjs"
      },
      {
        "name": "b",
        "import": "./b.cjs"
      }
    ],
    "strictExecutionOrder": true,
    "preserveEntrySignatures": "allow-extension",
    "codeSplitting": {
      "groups": [
        {
          "name": "bee",
          "test": "[\\\\/](?:b\\.cjs|s1\\.mjs)$",
          "includeDependenciesRecursively": false
        }
      ]
    },
    "experimental": {
      "onDemandWrapping": true
    }
  },
  "configVariants": [
    {
      "_configName": "wrap-all",
      "onDemandWrapping": false
    }
  ]
}
