# warnings

## INEFFECTIVE_DYNAMIC_IMPORT

```text
[INEFFECTIVE_DYNAMIC_IMPORT] target.js is dynamically imported by a.js, b.js but also statically imported by a.js, dynamic import will not move module into another chunk.

```

# Assets

## a.js

```js
import { n as init_a, t as aTargetPromise } from "./a2.js";
init_a();
export { aTargetPromise };

```

## a2.js

```js
import { n as __exportAll, t as __esmMin } from "./rolldown-runtime.js";
//#region target.js
var target_exports = /* @__PURE__ */ __exportAll({ value: () => 1 });
(globalThis.log ??= []).push("target");
//#endregion
//#region a.js
var aTargetPromise;
function init_a() {
	return (init_a = __esmMin((() => {
		(globalThis.log ??= []).push("a:1");
		aTargetPromise = Promise.resolve().then(() => target_exports);
	})))();
}
//#endregion
export { init_a as n, target_exports as r, aTargetPromise as t };

```

