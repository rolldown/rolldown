import assert from "node:assert";
//#region common.js
function init() {
	globalThis.value = typeof globalThis.value === "number" ? globalThis.value + 1 : 0;
}
var common, _;
function init_common() {
	return (init_common = __esmMin((() => {
		common = "common";
		_ = /* @__PURE__ */ init();
	})))();
}
//#endregion
//#region page-a.js
function init_page_a() {
	return (init_page_a = __esmMin((() => {
		init_common();
		assert.strictEqual(globalThis.value, 0, "named retained-star re-export must initialize common before page-a");
	})))();
}
//#endregion
export { init_common as i, _ as n, common as r, init_page_a as t };

```

