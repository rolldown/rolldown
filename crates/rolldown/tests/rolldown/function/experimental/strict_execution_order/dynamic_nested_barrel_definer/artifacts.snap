```js
import { t as __esmMin } from "./rolldown-runtime.js";
//#region leaf.js
function init_leaf() {
	return (init_leaf = __esmMin((() => {
		(globalThis.__events ??= []).push("leaf");
	})))();
}
//#endregion
//#region definer.js
function makeValue() {
	return 5;
}
var value;
function init_definer() {
	return (init_definer = __esmMin((() => {
		(globalThis.__events ??= []).push("definer");
		value = makeValue();
	})))();
}
//#endregion
//#region barrel-inner.js
function init_barrel_inner() {
	return (init_barrel_inner = __esmMin((() => {
		init_definer();
	})))();
}
//#endregion
//#region barrel-outer.js
function init_barrel_outer() {
	return (init_barrel_outer = __esmMin((() => {
		init_barrel_inner();
	})))();
}
//#endregion
//#region reader.js
var readerValue;
function init_reader() {
	return (init_reader = __esmMin((() => {
		init_leaf();
		init_barrel_outer();
		(globalThis.__events ??= []).push("reader:" + value);
		readerValue = value + 100;
	})))();
}
//#endregion
//#region reader-host.js
function init_reader_host() {
	return (init_reader_host = __esmMin((() => {
		init_reader();
		(globalThis.__events ??= []).push("reader-host:" + readerValue);
	})))();
}
//#endregion
//#region dynamic-page.js
function init_dynamic_page() {
	return (init_dynamic_page = __esmMin((() => {
		init_reader_host();
		(globalThis.__events ??= []).push("dynamic-page");
	})))();
}
//#endregion
export { init_reader_host as n, init_dynamic_page as t };

