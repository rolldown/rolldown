{
  "configName": "wrap-all",
  "config": {
    "input": [
      {
        "name": "a",
        "import": "./a.js"
      },
      {
        "name": "c",
        "import": "./c.js"
      }
    ],
    "strictExecutionOrder": true,
    "codeSplitting": {
      "groups": [
        {
          "name": "group",
          "test": "[\\\\/](?:a|b)\\.js$"
        }
      ]
    }
  },
  "configVariants": [
    {
      "_configName": "on-demand",
      "onDemandWrapping": true
    }
  ]
}
