## main2.js

```js
import { t as init_reader } from "./reader.js";
import { t as __esmMin } from "./rolldown-runtime.js";
//#region setup.js
globalThis.setupValue = "ready";
//#endregion
//#region main.js
function init_main() {
	return (init_main = __esmMin((() => {
		init_reader();
	})))();
}
//#endregion
export { init_main as t };

```

