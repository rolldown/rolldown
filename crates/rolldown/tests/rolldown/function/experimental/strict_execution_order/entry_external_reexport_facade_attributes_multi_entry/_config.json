{
  "expectExecuted": false,
  "configName": "on-demand",
  "config": {
    "input": [
      {
        "name": "a",
        "import": "./a.js"
      },
      {
        "name": "b",
        "import": "./b.js"
      }
    ],
    "external": ["external"],
    "strictExecutionOrder": true,
    "codeSplitting": {
      "groups": [
        {
          "name": "shared",
          "test": "[\\\\/](?:a|b|reader|setup)\\.js$"
        }
      ]
    },
    "experimental": {
      "onDemandWrapping": true
    }
  },
  "configVariants": [
    {
      "_configName": "wrap-all",
      "onDemandWrapping": false
    }
  ]
}
