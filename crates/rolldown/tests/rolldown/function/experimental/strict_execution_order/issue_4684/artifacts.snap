## main2.js

```js
import { t as __esmMin } from "./rolldown-runtime.js";
import nodeAssert from "node:assert";
//#region setup.js
var setup;
function init_setup() {
	return (init_setup = __esmMin((() => {
		setup = () => {
			globalThis.foo = "foo";
		};
		setup();
	})))();
}
//#endregion
//#region read.js
var foo, read;
function init_read() {
	return (init_read = __esmMin((() => {
		foo = globalThis.foo;
		read = () => {
			console.log("read", foo);
		};
	})))();
}
//#endregion
//#region main.js
function init_main() {
	return (init_main = __esmMin((() => {
		init_setup();
		init_read();
		setup();
		read();
		import("./dynamic2.js");
		nodeAssert.strictEqual(globalThis.foo, "foo");
	})))();
}
//#endregion
export { init_read as n, read as r, init_main as t };

```

