# Assets

## main.js

```js
import nodeAssert from "node:assert";
// HIDDEN [\0rolldown/runtime.js]
//#region dep.js
function foo() {
	globalThis.value = 1;
}
var dep_default;
var init_dep = __toCommonJSInitMin((() => {
	dep_default = /*#__PURE__*/ foo();
}));
//#endregion
__toCommonJSInitMin((() => {
	init_dep();
	nodeAssert.strictEqual(globalThis.value, 1);
}))();
export { dep_default as dep };

```

