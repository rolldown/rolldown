## g.js

```js
import { t as init_m0 } from "./m0.js";
import { t as init_m3 } from "./m3.js";
import { t as __esmMin } from "./rolldown-runtime.js";
//#region m2.js
function init_m2() {
	return (init_m2 = __esmMin((() => {
		init_m0();
		init_m3();
		globalThis.logs.push("m2");
	})))();
}
//#endregion
//#region m1.js
function init_m1() {
	return (init_m1 = __esmMin((() => {
		init_m3();
		globalThis.logs.push("m1");
	})))();
}
//#endregion
export { init_m2 as n, init_m1 as t };

```

