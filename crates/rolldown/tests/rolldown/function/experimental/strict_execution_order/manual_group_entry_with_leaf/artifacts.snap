# Assets

## group-0.js

```js
import { n as init_m2, t as init_m1 } from "./m1.js";
import { t as __esmMin } from "./rolldown-runtime.js";
//#region m4.js
function init_m4() {
	return (init_m4 = __esmMin((() => {
		console.log("m4");
	})))();
}
//#endregion
//#region main.js
function init_main() {
	return (init_main = __esmMin((() => {
		init_m1();
		init_m2();
		console.log("m0");
	})))();
}
//#endregion
export { init_m4 as n, init_main as t };

```

