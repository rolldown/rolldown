# Assets

## group-0.js

```js
import { n as init_leafhost } from "./group-l.js";
import { t as init_x } from "./x.js";
import { t as __esmMin } from "./rolldown-runtime.js";
//#region y.js
function init_y() {
	return (init_y = __esmMin((() => {
		console.log("Y");
	})))();
}
//#endregion
//#region main.js
function init_main() {
	return (init_main = __esmMin((() => {
		init_x();
		init_leafhost();
		console.log("A");
	})))();
}
//#endregion
export { init_y as n, init_main as t };

```

