# warnings

## INVALID_OPTION

```text
[INVALID_OPTION] `preserveEntrySignatures: 'allow-extension'` is set implicitly by Rolldown

- `codeSplitting.includeDependenciesRecursively = false` requires `preserveEntrySignatures` to be either `false` or 'allow-extension'

To fix:

- Set `preserveEntrySignatures` either to `false` or 'allow-extension' in your config

```

# Assets

## b.js

```js
import { r as init_m4 } from "./group-0.js";
import { t as __esmMin } from "./rolldown-runtime.js";
//#region b.js
function init_b() {
	return (init_b = __esmMin((() => {
		init_m4();
		globalThis.__loadM6 = () => import("./m6.js");
		console.log("B");
	})))();
}
//#endregion
export { init_b as t };

```

## group-0.js

```js
import { t as init_b } from "./b.js";
import { t as __esmMin } from "./rolldown-runtime.js";
//#region m4.js
function init_m4() {
	return (init_m4 = __esmMin((() => {
		console.log("M4");
	})))();
}
//#endregion
//#region main.js
function init_main() {
	return (init_main = __esmMin((() => {
		init_b();
		console.log("A");
	})))();
}
function init_m6() {
	return (init_m6 = __esmMin((() => {
		console.log("M6");
	})))();
}
//#endregion
export { init_main as n, init_m4 as r, init_m6 as t };

