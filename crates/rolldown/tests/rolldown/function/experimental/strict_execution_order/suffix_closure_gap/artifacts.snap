	globalThis.foo = "foo";
};
setup();
//#endregion
//#region reader.js
const captured = globalThis.foo;
console.log("captured", captured);
//#endregion
//#region main.js
function init_main() {
	return (init_main = __esmMin((() => {
		setup();
		import("./dyn.js");
	})))();
}
//#endregion
export { setup as n, init_main as t };

```

