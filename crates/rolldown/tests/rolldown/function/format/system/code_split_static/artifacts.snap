# Assets

## entry2.js

```js
System.register(["./shared.js"], (function() {
	"use strict";
	var shared;
	return {
		setters: [function(module) {
			shared = module.shared;
		}],
		execute: (function() {
			//#region entry2.js
			console.log(shared + 1);
			//#endregion
		})
	};
}));

```

