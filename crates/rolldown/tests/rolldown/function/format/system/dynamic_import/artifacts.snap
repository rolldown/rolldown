# Assets

## lazy.js

```js
System.register([], (function(exports) {
	"use strict";
	return { execute: (function() {
		exports("value", 42);
		//#endregion
	}) };
}));

```

## main.js

```js
System.register([], (function(module) {
	"use strict";
	return { execute: (function() {
		//#region main.js
		async function run() {
			const m = await module.import("./lazy.js");
			console.log(m.value);
		}
		run();
		//#endregion
	}) };
}));

```
