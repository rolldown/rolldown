{
  "config": {
    "strictExecutionOrder": true,
    "codeSplitting": {
      "includeDependenciesRecursively": false,
      "groups": [
        {
          "name": "first",
          "test": "[\\\\/]first\\.js$"
        },
        {
          "name": "second",
          "test": "[\\\\/]second\\.js$|^\\0rolldown/runtime\\.js$"
        }
      ]
    }
  },
  "configVariants": [
    {
      "_configName": "on-demand",
      "strictExecutionOrder": true,
      "onDemandWrapping": true
    }
  ]
}
