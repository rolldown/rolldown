## main.js

```js
require("./server.js");
var external_lib = require("external-lib");
Object.keys(external_lib).forEach(function(k) {
	if (k !== "default" && !Object.prototype.hasOwnProperty.call(exports, k)) Object.defineProperty(exports, k, {
		enumerable: true,
		get: function() {
			return external_lib[k];
		}
	});
});

```

