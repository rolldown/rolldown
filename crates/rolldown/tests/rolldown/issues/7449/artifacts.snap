## env.js

```js
import "./dep.js";
//#region env.js
const state = { config: {
	REQUEST_TIMEOUT_MS: "300000",
	marker: "dep"
} };
function getEnvString(key) {
	return state.config?.[key];
}
function getEnvInt(key) {
	return Number(getEnvString(key) || 3e5);
}
//#endregion
export { getEnvString as n, getEnvInt as t };

```

