## sorter2.js

```js
//#region resolve.js
const counter = new SomethingNew();
function resolveJsFrom(base, id) {
	return counter;
}
//#endregion
//#region sorting.js
function sort(input) {
	return resolveJsFrom(input, "some-pkg");
}
//#endregion
//#region sorter.js
function createSorter() {
	return {
		sort,
		resolveJsFrom
	};
}
//#endregion
export { resolveJsFrom as n, createSorter as t };

```

