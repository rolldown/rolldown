	node_2: () => node_2,
	reexport_2_3: () => node_3
});
globalThis.__acyclic_output_fuzz_2 = 2;
var node_2 = {};
node_2.value = 2;

//#endregion
export { node_2, node_3 as reexport_2_3, node2_exports as t };
