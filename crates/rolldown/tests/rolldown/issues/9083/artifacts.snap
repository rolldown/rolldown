//#region deep.js
function sleep(ms) {
	return new Promise((resolve) => setTimeout(resolve, ms));
}
await sleep(100);
//#endregion
//#region middle.js
const manager = {
	value: "hello",
	ready: false
};
function setup() {
	manager.ready = true;
}
//#endregion
//#region main.js
setup();
//#endregion
export { manager };

```

