# Assets

## input-options.js

```js
//#region plain-object.js
var PlainObjectLike = class {};
//#endregion
//#region normalize.js
function normalize(x) {
	return x;
}
//#endregion
//#region input-options.js
function preserveEntrySignatures(value) {
	return value;
}
function bindingifyInputOptions(opts) {
	return normalize(opts);
}
//#endregion
export { preserveEntrySignatures as n, PlainObjectLike as r, bindingifyInputOptions as t };

```

## main.js

```js
import { r as PlainObjectLike, t as bindingifyInputOptions } from "./input-options.js";
//#region output-impl.js
var RolldownOutputImpl = class extends PlainObjectLike {};
//#endregion
//#region main.js
function build(opts) {
	bindingifyInputOptions(opts);
	return new RolldownOutputImpl();
}
//#endregion
export { build };

```

