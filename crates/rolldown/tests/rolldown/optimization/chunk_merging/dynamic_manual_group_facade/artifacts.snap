//#region main.js
const [a, b, c] = await Promise.all([
	import("./shared-abc.js").then((n) => n.r),
	import("./shared-abc.js").then((n) => n.n),
	import("./shared-abc.js").then((n) => n.t)
]);
if (`${a.A}${b.B}${c.C}` !== "ABC") throw new Error("unexpected dynamic namespace result");
//#endregion

```

