# Assets

## foo.js

```js
//#region foo.js
const foo = "foo";
//#endregion
export { foo };

```

## main.js

```js
import "./foo.js";
import { strictEqual } from "node:assert";
//#region main.js
strictEqual("foo", "foo");
import("./foo.js").then((mod) => {
	strictEqual(mod.foo, "foo");
});
//#endregion

```

# Variant: [format: Cjs]

## Assets

### foo.js

```js
//#region foo.js
const foo = "foo";
//#endregion
exports.foo = foo;

```

### main.js

```js
require("./foo.js");
let node_assert = require("node:assert");
//#region main.js
(0, node_assert.strictEqual)("foo", "foo");
Promise.resolve().then(() => require("./foo.js")).then((mod) => {
	(0, node_assert.strictEqual)(mod.foo, "foo");
});
//#endregion

```
