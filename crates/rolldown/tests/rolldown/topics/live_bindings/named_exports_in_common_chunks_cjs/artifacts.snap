# Assets

## async-entry.js

```js

const require_shared = require('./shared.js');
const node_assert = __toESM(require("node:assert"));

//#region async-entry.js
require_shared.d();
node_assert.default.strictEqual(require_shared.b, 0);
node_assert.default.strictEqual(require_shared.b, require_shared.b);
require_shared.c();
node_assert.default.strictEqual(require_shared.b, 1);
node_assert.default.strictEqual(require_shared.b, require_shared.b);
require_shared.c();
node_assert.default.strictEqual(require_shared.b, 2);
node_assert.default.strictEqual(require_shared.b, require_shared.b);

//#endregion
```
## main.js

```js
const require_shared = require('./shared.js');

//#region main.js
Promise.resolve().then(() => require("./async-entry.js"));

//#endregion
Object.defineProperty(exports, 'count', {
  enumerable: true,
  get: function () {
    return require_shared.b;
  }
});
exports.inc = require_shared.c;
exports.reset = require_shared.d;
```
## shared.js

```js

//#region shared.js
let count = 0;
function reset() {
	count = 0;
}
function inc() {
	count += 1;
}

//#endregion
Object.defineProperty(exports, 'b', {
  enumerable: true,
  get: function () {
    return count;
  }
});
Object.defineProperty(exports, 'c', {
  enumerable: true,
  get: function () {
    return inc;
  }
});
Object.defineProperty(exports, 'd', {
  enumerable: true,
  get: function () {
    return reset;
  }
});
```
