## Assets

### main.js

```js
import { t as __esmMin } from "./rolldown-runtime.js";
//#region main.js
var loaded;
//#endregion
__esmMin((() => {
	loaded = import("./tla-target.js").then((mod) => mod.value);
}))();
export { loaded };

```

