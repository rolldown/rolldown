# Variant: wrap-all: [strict_execution_order: true]

## Assets

### a.js

```js
import { t as __esmMin } from "./rolldown-runtime.js";
import { n as shared, t as init_shared } from "./shared.js";
//#region a.js
var a;
//#endregion
await __esmMin((async () => {
	await init_shared();
	a = `a:${shared}`;
}))();
export { a };

```

### b.js

```js
