# Variant: wrap-all: [strict_execution_order: true]

## Assets

### a.js

```js
import { n as init_a, t as a } from "./a2.js";
await init_a();
export { a };

```

### a2.js

```js
import { n as shared, t as init_shared } from "./shared.js";
import { t as __esmMin } from "./rolldown-runtime.js";
//#region a.js
var a;
function init_a() {
	return (init_a = __esmMin((async () => {
		await init_shared();
		a = `a:${shared}`;
	})))();
}
//#endregion
export { init_a as n, a as t };

```

