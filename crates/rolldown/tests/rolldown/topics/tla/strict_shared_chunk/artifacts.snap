export { __esmMin as t };

```

### shared.js

```js
import { t as __esmMin } from "./rolldown-runtime.js";
//#region shared.js
var shared;
var init_shared = __esmMin((async () => {
	shared = await Promise.resolve("shared");
}));
//#endregion
export { shared as n, init_shared as t };

```

