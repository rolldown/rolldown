## main.js

```js
//#region main.js
import("./then_lib.js").then((ns) => {
	const { a } = ns;
	const { b = 1 } = ns;
	const { c, ...rest } = ns;
	console.log(a, b, c, ns.d, rest.e);
});
const m = await import("./await_lib.js");
const { used } = m;
const { used: used2 } = m;
const { reExported } = m;
console.log(used, used2, m.member);
//#endregion
export { reExported };

```

