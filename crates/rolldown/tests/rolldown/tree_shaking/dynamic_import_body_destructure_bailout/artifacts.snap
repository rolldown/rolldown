## main.js

```js
//#region main.js
const k = globalThis.k;
import("./computed_lib.js").then((ns) => {
	const { [k]: x } = ns;
	console.log(x);
});
let m = await import("./reassigned_lib.js");
m = { a: 1 };
const { a } = m;
console.log(a);
//#endregion

```

