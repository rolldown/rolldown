{
  "extends": "../../../tsconfig.json",
  "include": ["src/*", "src/**/*", "**/_config.ts", "**/*.test.ts", "**/*.test-d.ts"],
  "compilerOptions": {
    "types": ["node", "vite/client"],
    "rootDir": "./",
    "allowJs": true,
    "isolatedDeclarations": false,
    // Mirrors the `@tests` alias in vitest.config.mts so type checking (and
    // knip's import resolution) can follow `@tests/*` imports.
    "paths": {
      "@tests/*": ["./src/*"]
    }
  }
}
