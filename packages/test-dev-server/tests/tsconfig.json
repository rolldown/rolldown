{
  "extends": "../../../tsconfig.json",
  "include": [
    "src/*",
    "src/**/*",
    "playground/**/*.ts",
    "**/_config.ts",
    "**/*.test.ts",
    "**/*.spec.ts"
  ],
  "compilerOptions": {
    "types": ["node"],
    "rootDir": "./",
    "allowJs": true,
    "isolatedDeclarations": false,
    "paths": {
      "~utils": ["./playground/test-utils.ts"]
    }
  }
}
