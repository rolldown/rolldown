-const { MessageHandler, instantiateNapiModuleSync, instantiateNapiModule } = require('@emnapi/core')
-const { getDefaultContext } = require('@emnapi/runtime')
+const {
+  MessageHandler,
+  instantiateNapiModuleSync: __instantiateNapiModuleSync,
+  instantiateNapiModule: __instantiateNapiModule,
+} = require('@emnapi/core')
+// Single-threaded (non-shared-memory) WASI builds link an emnapi archive
+// without the C async-work and threadsafe-function implementations (they are
+// unconditional `napi_generic_failure` stubs without threads), so
+// instantiation must provide the JavaScript implementations through these
+// plugins. Threaded (shared-memory) builds link the C implementations and
+// ignore the plugins; this mirrors the upstream @emnapi/core v2 plugin split
+// (v1 bundled these implementations in the core runtime unconditionally).
+const {
+  asyncWork: emnapiAsyncWorkPlugin,
+  tsfn: emnapiTSFNPlugin,
+} = require('@emnapi/core/plugins')
+const { createContext, getDefaultContext } = require('@emnapi/runtime')
 const { WASI } = require('@tybys/wasm-util')
 
 const { createFsProxy, createOnMessage } = require('./dist/fs-proxy.cjs')
 
+// emnapi v1 compatibility: v1's instantiateNapiModule(Sync) always carried the
+// async-work/threadsafe-function implementations, so callers never passed
+// plugins. Default them when the caller provides none; `plugins: []` remains
+// an explicit opt-out.
+const __withDefaultPlugins = (options) =>
+  options && options.plugins != null
+    ? options
+    : { ...options, plugins: [emnapiAsyncWorkPlugin, emnapiTSFNPlugin] }
+
+const instantiateNapiModule = (wasmInput, options) =>
+  __instantiateNapiModule(wasmInput, __withDefaultPlugins(options))
+const instantiateNapiModuleSync = (wasmInput, options) =>
+  __instantiateNapiModuleSync(wasmInput, __withDefaultPlugins(options))
+
 module.exports = {
   MessageHandler,
+  createContext,
+  emnapiAsyncWorkPlugin,
+  emnapiTSFNPlugin,
   instantiateNapiModule,
   instantiateNapiModuleSync,
   getDefaultContext,
